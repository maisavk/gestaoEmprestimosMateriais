@page "/emprestimos"
@rendermode InteractiveServer
@inject GestaoEmprestimos.Application.EmprestimoService Service

<div class="container mt-4">
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0">Registrar Nova Solicitação de Empréstimo</h4>
        </div>
        <div class="card-body p-4 bg-light">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Estudante Beneficiário</label>
                    <select class="form-select form-select-lg" @bind="selA">
                        <option value="">-- Selecione o Estudante --</option>
                        @foreach(var a in Service.Alunos){
                            <option value="@a.Nome">@a.Nome</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Professor Solicitante</label>
                    <select class="form-select form-select-lg" @bind="selP">
                        <option value="">-- Selecione o Professor --</option>
                        @foreach(var p in Service.Professores){
                            <option value="@p">@p</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Material Didático Adaptado</label>
                    <select class="form-select form-select-lg" @bind="selM">
                        <option value="">-- Selecione o Material --</option>
                        @foreach(var m in Service.Materiais){
                            <option value="@m.Titulo">@m.Titulo (@m.QuantidadeDisponivel disponíveis)</option>
                        }
                    </select>
                </div>
            </div>
            <div class="text-end mt-4">
                <button class="btn btn-warning btn-lg px-5 fw-bold text-dark shadow-sm" @onclick="Solicitar">Enviar Solicitação</button>
            </div>
            @if(!string.IsNullOrEmpty(msg)){
                <div class="alert alert-info mt-3 shadow-sm" role="alert">
                    @msg
                </div>
            }
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white py-3">
            <h5 class="mb-0">Histórico Geral e Controle de Fluxo</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-center">
                    <thead class="table-light">
                        <tr>
                            <th>Estudante</th>
                            <th>Material</th>
                            <th>Período do Empréstimo</th>
                            <th>Situação Atual</th>
                            <th>Avaliação de Adequação</th>
                            <th>Ações Administrativas</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var emp in Service.Emprestimos){
                            <tr>
                                <td class="fw-bold">@emp.Aluno.Nome</td>
                                <td>@emp.Material.Titulo</td>
                                <td class="text-muted">@emp.DataRetirada.ToShortDateString() até @emp.PrazoDevolucao.ToShortDateString()</td>
                                <td><span class="badge @(emp.Situacao == "Solicitado" ? "bg-warning text-dark" : emp.Situacao == "Aprovado" ? "bg-info text-white" : "bg-success") px-3 py-2">@emp.Situacao</span></td>
                                <td class="fst-italic text-secondary">@(string.IsNullOrEmpty(emp.Avaliacao) ? "Pendente" : emp.Avaliacao)</td>
                                <td>
                                    @if(emp.Situacao == "Solicitado"){
                                        <button class="btn btn-sm btn-outline-success fw-bold px-3 shadow-sm" @onclick="() => { Service.AprovarMovimentacao(emp); StateHasChanged(); }">Aprovar Retirada</button>
                                    }
                                    @if(emp.Situacao == "Aprovado"){
                                        <button class="btn btn-sm btn-outline-danger fw-bold px-3 shadow-sm" @onclick="() => { Service.DevolverMovimentacao(emp); StateHasChanged(); }">Registrar Devolução</button>
                                    }
                                    @if(emp.Situacao == "Devolvido"){
                                        <span class="text-success fw-bold">Finalizado</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code { 
    string selA = ""; string selP = ""; string selM = ""; string msg = ""; 

    void Solicitar() { 
        if (string.IsNullOrEmpty(selA) || string.IsNullOrEmpty(selP) || string.IsNullOrEmpty(selM)) {
            msg = "Por favor, selecione todos os campos obrigatórios.";
            return;
        }

        var objAluno = Service.Alunos.FirstOrDefault(x => x.Nome == selA) ?? new GestaoEmprestimos.Domain.Entities.Aluno("RA999", selA);
        var objMaterial = Service.Materiais.FirstOrDefault(x => x.Titulo == selM) ?? new GestaoEmprestimos.Domain.Entities.Material(999, selM, default, "999", "Acessibilidade", "", 1);

        Service.Emprestimos.Add(new GestaoEmprestimos.Application.EmprestimoMoc {
            Id = Guid.NewGuid().ToString().Substring(0,5),
            Aluno = objAluno,
            Professor = selP,
            Material = objMaterial,
            DataRetirada = DateTime.Now,
            PrazoDevolucao = DateTime.Now.AddDays(7),
            Situacao = "Solicitado"
        });

        msg = "Solicitação realizada com sucesso!";
        StateHasChanged();
    } 
}
