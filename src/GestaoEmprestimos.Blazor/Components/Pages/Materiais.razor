@page "/materiais"
@rendermode InteractiveServer
@inject GestaoEmprestimos.Application.EmprestimoService Service
<div class="container mt-4">
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0">Materiais Didáticos Adaptados</h4>
        </div>
        <div class="card-body p-4 bg-light">
            <h5>Novo Material</h5>
            <div class="row g-3">
                <div class="col-md-4"><label class="form-label fw-bold">Título:</label><input @bind="t" class="form-control" placeholder="Ex: Quadro Magnético" /></div>
                <div class="col-md-4"><label class="form-label fw-bold">Código:</label><input @bind="c" class="form-control" placeholder="Ex: 2312" /></div>
                <div class="col-md-4"><label class="form-label fw-bold">Qtd Disponível:</label><input type="number" @bind="q" class="form-control" /></div>
            </div>
            <div class="row mt-3">
                <div class="col-md-12"><label class="form-label fw-bold">Descrição / Área de Conhecimento / Recursos de Acessibilidade:</label><input @bind="d" class="form-control" placeholder="Ex: Área: Matemática. Recursos: Alto-relevo" /></div>
            </div>
            <div class="text-end mt-3">
                <button class="btn btn-primary btn-lg px-4 fw-bold" @onclick="Salvar">Cadastrar Material</button>
            </div>
        </div>
    </div>
    <table class="table table-hover text-center align-middle">
        <thead class="table-dark">
            <tr>
                <th>Código (ID)</th>
                <th>Título</th>
                <th>Especificações de Acessibilidade / Descrição</th>
                <th>Qtd Estoque</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var m in Service.Materiais){
                <tr>
                    <td>@m.Id</td>
                    <td class="fw-bold">@m.Titulo</td>
                    <td>@m.Descricao</td>
                    <td><span class="badge bg-info px-3 py-2 text-white">@m.QuantidadeDisponivel</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>
@code { 
    string t = ""; string c = ""; string d = ""; int q = 1; 
    void Salvar() { 
        if(!string.IsNullOrEmpty(t)) { 
            Service.CadastrarMaterialCompleto(t, c, d, q); 
            t=""; c=""; d=""; q=1; 
            StateHasChanged();
        } 
    } 
}
