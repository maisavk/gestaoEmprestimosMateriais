@page "/materiais"
@using GestaoEmprestimos.Application
@using GestaoEmprestimos.Domain.Entities
@using GestaoEmprestimos.Domain.Enums
@inject EmprestimoService Service
@rendermode InteractiveServer

<PageTitle>Materiais Adaptados</PageTitle>

<h1>Gestăo de Materiais Didáticos</h1>

<div class="card p-3 mb-4">
    <h4>Cadastrar Novo Material</h4>
    <div class="row g-3">
        <div class="col-md-4">
            <input @bind="novoTitulo" class="form-control" placeholder="Título do Material" />
        </div>
        <div class="col-md-3">
            <select @bind="tipoSelecionado" class="form-select">
                @foreach (var tipo in Enum.GetValues<TipoMaterial>())
                {
                    <option value="@tipo">@tipo</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <input type="number" @bind="novaQtd" class="form-control" placeholder="Qtd" />
        </div>
        <div class="col-md-3">
            <button class="btn btn-primary w-100" @onclick="Adicionar">Registrar Material</button>
        </div>
    </div>
</div>

<div class="mb-3">
    <input type="text" @bind="termoBusca" @bind:event="oninput" class="form-control" placeholder="?? Buscar material por título ou área..." />
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Título</th>
            <th>Tipo</th>
            <th>Estoque</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in MateriaisFiltrados)
        {
            <tr>
                <td>@m.Id</td>
                <td>@m.Titulo</td>
                <td>@m.Tipo</td>
                <td>@m.QuantidadeDisponivel</td>
                <td>
                    <span class="badge @(m.QuantidadeDisponivel > 0 ? "bg-success" : "bg-danger")">
                        @(m.QuantidadeDisponivel > 0 ? "Disponível" : "Esgotado")
                    </span>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private string termoBusca = "";
    private string novoTitulo = "";
    private int novaQtd = 1;
    private TipoMaterial tipoSelecionado = TipoMaterial.Braille;

    private List<Material> MateriaisFiltrados => Service.ListarMateriais()
        .Where(m => string.IsNullOrWhiteSpace(termoBusca) || 
               m.Titulo.Contains(termoBusca, StringComparison.OrdinalIgnoreCase)).ToList();

    private void Adicionar()
    {
        if (!string.IsNullOrWhiteSpace(novoTitulo))
        {
            int proxId = Service.ListarMateriais().Count + 1;
            var material = new Material(proxId, novoTitulo, tipoSelecionado, "Cadastrado via Web", "Geral", "N/A", novaQtd);
            Service.CadastrarMaterial(material);
            novoTitulo = "";
        }
    }
}
