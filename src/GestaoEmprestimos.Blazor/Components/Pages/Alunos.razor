@page "/alunos"
@rendermode InteractiveServer
@inject GestaoEmprestimos.Application.EmprestimoService Service
<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-success text-white py-3">
            <h4 class="mb-0">Gerenciar Estudantes Beneficiários</h4>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-5 border-end">
                    <h5 class="text-success mb-3">Novo Estudante</h5>
                    <div class="mb-3"><label class="form-label fw-bold">Registro Acadêmico (RA):</label><input @bind="ra" class="form-control form-control-lg" placeholder="Ex: RA12345" /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Nome Completo:</label><input @bind="nomeA" class="form-control form-control-lg" placeholder="Ex: Maria Souza" /></div>
                    <button class="btn btn-success btn-lg w-100 mt-2 fw-bold" @onclick="AddA">Salvar Estudante</button>
                </div>
                <div class="col-md-7 ps-4">
                    <h5 class="text-muted mb-3">Estudantes Cadastrados</h5>
                    <div class="list-group">
                        @foreach(var a in Service.Alunos){
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span class="fw-bold">@a.Nome</span><span class="badge bg-secondary rounded-pill">RA: @ObterIdentificador(a)</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@code { 
    string ra = ""; string nomeA = "";
    void AddA() { if(!string.IsNullOrEmpty(ra) && !string.IsNullOrEmpty(nomeA)){ Service.CadastrarEstudante(ra, nomeA); ra=""; nomeA=""; } } 
    string ObterIdentificador(object obj) { 
        if (obj == null) return ""; 
        try { dynamic d = obj; return d.RA?.ToString() ?? d.Matricula?.ToString() ?? d.Codigo?.ToString() ?? d.Id?.ToString() ?? ""; } catch { return ""; } 
    } 
}
